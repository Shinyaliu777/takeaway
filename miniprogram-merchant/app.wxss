page {
  background: #f3efe8;
  color: #181a1f;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-panel {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(220, 204, 177, 0.12), transparent 34%),
    linear-gradient(160deg, #17191f 0%, #1d2430 100%);
  color: #f8f3eb;
  border-radius: 28rpx;
  padding: 34rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 20rpx 40rpx rgba(21, 25, 34, 0.16);
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.88;
  margin-bottom: 12rpx;
  color: #cab495;
}

.title {
  display: block;
  font-size: 60rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.04;
}

.hero-line {
  display: block;
  margin-top: 12rpx;
  color: #d7dce5;
  font-size: 30rpx;
  line-height: 1.56;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.hero-stat {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 20rpx;
  padding: 22rpx 22rpx;
  min-height: 132rpx;
  box-sizing: border-box;
}

.hero-stat-label {
  display: block;
  font-size: 24rpx;
  color: #d5b991;
}

.hero-stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.06;
  margin-top: 10rpx;
}

.card {
  background: rgba(255, 252, 247, 0.96);
  border-radius: 24rpx;
  padding: 26rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(204, 194, 178, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(41, 39, 36, 0.06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 10rpx 16rpx;
  margin-bottom: 14rpx;
}

.section-title {
  display: block;
  flex: 1;
  min-width: 0;
  font-size: 44rpx;
  font-weight: 800;
  color: #1b1d22;
}

.section-subtitle {
  display: block;
  color: #77685a;
  font-size: 24rpx;
  line-height: 1.5;
  text-align: right;
}

.line {
  display: block;
  margin-top: 8rpx;
  color: #5d5247;
  font-size: 28rpx;
}

.strong {
  color: #1b1d22;
  font-weight: 600;
}

.muted {
  color: #7a7067;
}

.pill {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 8rpx;
}

.pill-blue {
  background: #dbeafe;
  color: #1d4ed8;
}

.pill-amber {
  background: #fef3c7;
  color: #b45309;
}

.pill-green {
  background: #dcfce7;
  color: #15803d;
}

.pill-slate {
  background: #e2e8f0;
  color: #334155;
}

.input,
picker .input {
  height: 76rpx;
  background: #fffaf3;
  border-radius: 16rpx;
  border: 1rpx solid #ddd0bf;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  color: #1b1d22;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  min-height: 72rpx;
  line-height: 1.2;
  padding: 0 18rpx;
  font-weight: 700;
  white-space: normal;
  text-align: center;
}

.primary-btn {
  background: linear-gradient(135deg, #17191f, #2b3240);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(23, 25, 31, 0.14);
}

.secondary-btn {
  background: #ebe1d3;
  color: #1b1d22;
}

.secondary-btn::after,
.primary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: 0;
}

.ghost-btn {
  background: #fff9f1;
  color: #4d4034;
  border: 1rpx solid #ddd0bf;
}

.danger-btn {
  background: #fff1f2;
  color: #be123c;
  border: 1rpx solid #fecdd3;
}

.form-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0 4rpx;
}

.action-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.data-card {
  background: #ffffff;
  border-radius: 14rpx;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  padding: 18rpx;
  margin-bottom: 12rpx;
  box-shadow: none;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.textarea {
  min-height: 148rpx;
  background: #f8fafc;
  border: 1rpx solid #d8e0e8;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #0f172a;
  margin-bottom: 14rpx;
  width: 100%;
  line-height: 1.6;
}
