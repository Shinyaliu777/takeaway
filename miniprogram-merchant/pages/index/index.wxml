<view class="page merchant-home">
  <view class="hero-panel dashboard-hero">
    <text class="eyebrow">运营控制台</text>
    <text class="title">今天先处理要出单的事</text>
    <text class="hero-line">付款审核、待配送和消息提醒优先，经营数据放在第二层查看。</text>
    <view class="hero-meta-row">
      <text class="hero-meta-chip hero-meta-chip-strong">{{tokenReady ? '在线处理中' : '等待登录'}}</text>
      <text class="hero-meta-chip">待处理 {{todoCount}}</text>
    </view>
  </view>

  <view class="card task-card">
    <view class="section-head section-head-compact">
      <view>
        <text class="section-title">今日待办</text>
        <text class="section-subtitle section-subtitle-left">先处理会影响履约和用户感知的任务。</text>
      </view>
      <text class="section-badge">共 {{todoCount}} 项</text>
    </view>
    <view class="queue-list">
      <view class="queue-item queue-item-primary" hover-class="queue-item-hover" bindtap="goOrders">
        <view class="queue-copy-wrap">
          <text class="queue-title">待审付款</text>
          <text class="queue-copy">确认到账后才能进入配送。</text>
        </view>
        <text class="queue-value">{{pendingReviewCount}}</text>
      </view>
      <view class="queue-item" hover-class="queue-item-hover" bindtap="goOrders">
        <view class="queue-copy-wrap">
          <text class="queue-title">待配送</text>
          <text class="queue-copy">已付款订单等待出餐配送。</text>
        </view>
        <text class="queue-value">{{pendingDeliveryCount}}</text>
      </view>
      <view class="queue-item" hover-class="queue-item-hover" bindtap="goMessages">
        <view class="queue-copy-wrap">
          <text class="queue-title">未读消息</text>
          <text class="queue-copy">订单提醒和系统通知。</text>
        </view>
        <text class="queue-value">{{unreadMessageCount}}</text>
      </view>
    </view>
  </view>

  <view class="card data-card">
    <view class="section-head">
      <text class="section-title">今日经营结果</text>
      <text class="section-subtitle section-subtitle-left">快速扫数，不抢任务注意力。</text>
    </view>
    <view class="kpi-grid">
      <view class="kpi-card">
        <text class="kpi-label">今日订单</text>
        <text class="kpi-value">{{todayOrderCount}}</text>
      </view>
      <view class="kpi-card">
        <text class="kpi-label">今日销售额</text>
        <text class="kpi-value">MYR {{todayRevenue}}</text>
      </view>
      <view class="kpi-card">
        <text class="kpi-label">启用规则</text>
        <text class="kpi-value">{{activeRuleCount}}</text>
      </view>
      <view class="kpi-card">
        <text class="kpi-label">推荐位</text>
        <text class="kpi-value">{{featuredEnabled ? '已开启' : '未开启'}}</text>
      </view>
    </view>
  </view>

  <view class="card data-card shortcut-card">
    <view class="section-head">
      <text class="section-title">常用入口</text>
      <text class="section-subtitle section-subtitle-left">高频操作放前面，设置放后面。</text>
    </view>
    <view class="shortcut-grid">
      <view class="shortcut-item shortcut-item-primary" hover-class="shortcut-item-hover" bindtap="goOrders">
        <text class="shortcut-title">订单管理</text>
        <text class="shortcut-copy">审核和配送</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goRules">
        <text class="shortcut-title">规则管理</text>
        <text class="shortcut-copy">套餐和价格</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goProducts">
        <text class="shortcut-title">商品管理</text>
        <text class="shortcut-copy">库存和上下架</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goMessages">
        <text class="shortcut-title">消息列表</text>
        <text class="shortcut-copy">提醒和通知</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goUsers">
        <text class="shortcut-title">用户中心</text>
        <text class="shortcut-copy">用户和订单</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goCategories">
        <text class="shortcut-title">分类管理</text>
        <text class="shortcut-copy">菜单结构</text>
      </view>
      <view class="shortcut-item" hover-class="shortcut-item-hover" bindtap="goShop">
        <text class="shortcut-title">店铺设置</text>
        <text class="shortcut-copy">营业和展示</text>
      </view>
      <view class="shortcut-item shortcut-item-danger" hover-class="shortcut-item-hover" bindtap="logout">
        <text class="shortcut-title">退出登录</text>
        <text class="shortcut-copy">结束当前会话</text>
      </view>
    </view>
  </view>
</view>
