.hero-grid {
  grid-template-columns: 1fr 1fr;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.quick-card {
  margin: 0;
  padding: 22rpx;
  min-height: 176rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f8fb 100%);
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  text-align: left;
  box-shadow: none;
}

.quick-card::after {
  border: 0;
}

.quick-card-primary {
  background: linear-gradient(135deg, #0f172a, #334155);
}

.quick-card-danger {
  background: linear-gradient(135deg, #3f1d2e, #7f1d1d);
}

.quick-card-primary .quick-icon,
.quick-card-primary .quick-title,
.quick-card-primary .quick-copy,
.quick-card-danger .quick-icon,
.quick-card-danger .quick-title,
.quick-card-danger .quick-copy {
  color: #f8fafc;
}

.quick-icon {
  display: block;
  font-size: 36rpx;
  color: #334155;
}

.quick-title {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.quick-copy {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}
