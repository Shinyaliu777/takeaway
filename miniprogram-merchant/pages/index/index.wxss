.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.hero-meta-chip {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #dbe4ee;
  font-size: 22rpx;
}

.hero-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.kpi-card {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.kpi-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.kpi-value {
  display: block;
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.todo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.quick-card {
  width: 100%;
  min-width: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  box-sizing: border-box;
  margin: 0;
  padding: 24rpx;
  min-height: 196rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f8fb 100%);
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  text-align: left;
  box-shadow: none;
}

.quick-card-primary {
  background: linear-gradient(135deg, #0f172a, #334155);
}

.quick-card-danger {
  background: linear-gradient(135deg, #3f1d2e, #7f1d1d);
}

.quick-card-primary .quick-icon,
.quick-card-primary .quick-title,
.quick-card-primary .quick-copy,
.quick-card-danger .quick-icon,
.quick-card-danger .quick-title,
.quick-card-danger .quick-copy {
  color: #f8fafc;
}

.quick-icon {
  display: block;
  font-size: 38rpx;
  color: #334155;
}

.quick-title {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #0f172a;
}

.quick-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.quick-link {
  display: block;
  margin-top: auto;
  padding-top: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

.quick-card-primary .quick-link,
.quick-card-danger .quick-link {
  color: #f8fafc;
}

.quick-card-hover {
  transform: translateY(-2rpx);
  opacity: 0.96;
}
