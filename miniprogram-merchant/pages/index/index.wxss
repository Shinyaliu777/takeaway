.merchant-home {
  padding-bottom: 28rpx;
  background:
    radial-gradient(circle at top left, rgba(29, 33, 40, 0.08), transparent 24%),
    linear-gradient(180deg, #f5f3ee 0%, #efebe4 100%);
}

.dashboard-hero {
  position: relative;
  overflow: hidden;
  padding: 28rpx 28rpx 22rpx;
  border: 1rpx solid rgba(39, 44, 39, 0.06);
  background: linear-gradient(145deg, #1d2227 0%, #273029 100%);
  box-shadow: 0 14rpx 26rpx rgba(21, 24, 28, 0.08);
}

.dashboard-hero .eyebrow,
.dashboard-hero .title,
.dashboard-hero .hero-line {
  color: #f8f2e8;
}

.dashboard-hero .hero-line {
  max-width: 620rpx;
  color: rgba(248, 242, 232, 0.72);
}

.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.hero-meta-chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  color: rgba(248, 242, 232, 0.82);
  font-size: 21rpx;
  font-weight: 600;
}

.hero-meta-chip-strong {
  background: #d6c3a1;
  border-color: transparent;
  color: #1d1814;
}

.task-card,
.data-card {
  margin-top: 18rpx;
}

.section-head-compact {
  margin-bottom: 10rpx;
}

.section-subtitle-left {
  max-width: 480rpx;
  text-align: left;
}

.section-badge {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #e6ddd0;
  color: #30271f;
  font-size: 21rpx;
  font-weight: 700;
}

.queue-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.queue-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
  background: #fcfbf8;
  border: 1rpx solid rgba(61, 67, 61, 0.08);
}

.queue-item-primary {
  background: linear-gradient(145deg, #1f2528 0%, #29332c 100%);
  border-color: rgba(17, 19, 24, 0.08);
}

.queue-item-primary .queue-title,
.queue-item-primary .queue-copy,
.queue-item-primary .queue-value {
  color: #f8fafc;
}

.queue-copy-wrap {
  flex: 1;
  min-width: 0;
}

.queue-title {
  display: block;
  font-size: 31rpx;
  font-weight: 800;
  color: #17191f;
}

.queue-copy {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #66594d;
}

.queue-value {
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 800;
  color: #17191f;
}

.queue-item-hover {
  transform: translateY(-2rpx);
  opacity: 0.96;
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.kpi-card {
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #fbfaf7;
  border: 1rpx solid rgba(61, 67, 61, 0.08);
  min-height: 128rpx;
  box-sizing: border-box;
}

.kpi-label {
  display: block;
  font-size: 22rpx;
  color: #70655a;
  font-weight: 600;
}

.kpi-value {
  display: block;
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #17191f;
  line-height: 1.12;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.shortcut-item {
  width: 100%;
  min-width: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  box-sizing: border-box;
  margin: 0;
  padding: 16rpx 16rpx 14rpx;
  min-height: 118rpx;
  border-radius: 16rpx;
  background: #fcfbf8;
  border: 1rpx solid rgba(61, 67, 61, 0.08);
  text-align: left;
}

.shortcut-item-primary {
  background: linear-gradient(145deg, #1f2528 0%, #29332c 100%);
  border-color: rgba(17, 19, 24, 0.08);
}

.shortcut-item-danger {
  background: linear-gradient(135deg, #5a3d23 0%, #7a572f 100%);
  border-color: rgba(122, 87, 47, 0.14);
}

.shortcut-item-primary .shortcut-title,
.shortcut-item-primary .shortcut-copy,
.shortcut-item-danger .shortcut-title,
.shortcut-item-danger .shortcut-copy {
  color: #f8fafc;
}

.shortcut-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.22;
  color: #17191f;
  font-weight: 800;
}

.shortcut-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #66594d;
}

.shortcut-item-hover {
  transform: translateY(-2rpx);
  opacity: 0.96;
}
