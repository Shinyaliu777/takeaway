.product-list-card {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
}

.filter-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.filter-pill {
  margin: 0;
  min-height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  color: #475569;
  font-size: 22rpx;
}

.filter-pill::after {
  border: 0;
}

.filter-pill-active {
  background: #0f172a;
  color: #f8fafc;
}

.product-list-card:last-child {
  border-bottom: 0;
}

.product-top {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.product-main {
  flex: 1;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.product-title {
  display: block;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.product-price {
  color: #b91c1c;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.product-summary {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.5;
}

.product-thumb {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #e2e8f0;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  box-shadow: none;
}

.product-actions-rail {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 128rpx;
  flex-shrink: 0;
}

.product-tool-btn {
  width: 100%;
  min-height: 62rpx;
  line-height: 62rpx;
  margin: 0;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.editor-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(226, 232, 240, 0.72);
}

.editor-section:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: 0;
}

.editor-section-title {
  display: block;
  margin-bottom: 12rpx;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #e2e8f0;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  text-align: center;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 160rpx;
  border-radius: 14rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #0f172a;
  margin-bottom: 14rpx;
  width: 100%;
}

.editor-card {
  margin-top: 6rpx;
}

.field-block {
  margin-bottom: 14rpx;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #334155;
  font-size: 22rpx;
  font-weight: 700;
}

.picker-input {
  margin-bottom: 0;
}

.image-upload-panel {
  display: flex;
  gap: 14rpx;
  align-items: stretch;
}

.image-preview-wrap {
  width: 156rpx;
  height: 156rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.image-upload-actions {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.upload-btn {
  margin: 0;
  min-height: 60rpx;
  line-height: 60rpx;
}

.upload-tip {
  color: #64748b;
  font-size: 22rpx;
  line-height: 1.6;
}

.field-grid {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.field-grid-item {
  flex: 1;
  margin-bottom: 0;
}

.editor-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.switch-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.switch-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  border-radius: 14rpx;
}

.switch-title {
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
}

.editor-primary,
.editor-secondary {
  flex: 1;
}

.empty-copy {
  padding: 18rpx 0 6rpx;
  color: #64748b;
  font-size: 24rpx;
}
