<view class="page">
  <view class="hero-panel">
    <text class="eyebrow">商品维护</text>
    <text class="title">商品管理</text>
    <text class="hero-line">先筛选，再改状态。</text>
    <view class="hero-meta-row">
      <text class="hero-meta-chip hero-meta-chip-strong">当前筛选 {{filteredProducts.length}}</text>
      <text class="hero-meta-chip">商品总数 {{products.length}}</text>
      <text class="hero-meta-chip">分类 / 时段 / 上架状态</text>
    </view>
  </view>
  <view class="card tool-card">
    <view class="filter-stack">
      <input class="input" placeholder="搜索商品名或分类" value="{{searchKeyword}}" bindinput="onSearchInput" />
      <view class="filter-row">
        <button class="filter-pill {{categoryFilter === 'all' ? 'filter-pill-active' : ''}}" size="mini" data-value="all" bindtap="setCategoryFilter">全部分类</button>
        <button wx:for="{{categories}}" wx:key="id" class="filter-pill {{categoryFilter == item.id ? 'filter-pill-active' : ''}}" size="mini" data-value="{{item.id}}" bindtap="setCategoryFilter">{{item.name}}</button>
      </view>
      <view class="filter-row">
        <button class="filter-pill {{periodFilter === 'all' ? 'filter-pill-active' : ''}}" size="mini" data-value="all" bindtap="setPeriodFilter">全部时段</button>
        <button class="filter-pill {{periodFilter === 'lunch' ? 'filter-pill-active' : ''}}" size="mini" data-value="lunch" bindtap="setPeriodFilter">午餐可点</button>
        <button class="filter-pill {{periodFilter === 'dinner' ? 'filter-pill-active' : ''}}" size="mini" data-value="dinner" bindtap="setPeriodFilter">晚餐可点</button>
      </view>
      <view class="filter-row">
        <button class="filter-pill {{saleFilter === 'all' ? 'filter-pill-active' : ''}}" size="mini" data-value="all" bindtap="setSaleFilter">全部状态</button>
        <button class="filter-pill {{saleFilter === 'on' ? 'filter-pill-active' : ''}}" size="mini" data-value="on" bindtap="setSaleFilter">仅上架</button>
        <button class="filter-pill {{saleFilter === 'off' ? 'filter-pill-active' : ''}}" size="mini" data-value="off" bindtap="setSaleFilter">仅下架</button>
      </view>
    </view>
    <view class="summary-banner">
      <view class="summary-copy-wrap">
        <text class="summary-banner-title">结果</text>
        <text class="summary-banner-copy">{{summaryText}}</text>
      </view>
      <button class="ghost-btn summary-clear-btn" size="mini" bindtap="clearFilters">清空筛选</button>
    </view>
  </view>
  <view class="card list-card">
    <view class="section-head">
      <text class="section-title">商品结果</text>
      <text class="section-subtitle">{{filteredProducts.length}} / {{products.length}}</text>
    </view>
    <view wx:for="{{filteredProducts}}" wx:key="id" class="product-list-card">
      <view class="product-top">
        <image wx:if="{{item.image_preview_url || item.image_url}}" class="product-thumb" src="{{item.image_preview_url || item.image_url}}" mode="aspectFill"></image>
        <view class="product-main">
          <view class="product-header">
            <text class="product-title">{{item.name}}</text>
            <text class="product-price">{{item.price_amount ? 'MYR ' + item.price_amount : '自动套餐价'}}</text>
          </view>
          <view class="meta-row">
            <text class="pill pill-slate">{{item.category_name}}</text>
            <text class="pill pill-slate">库存 {{item.stock_qty}}</text>
            <text class="pill pill-blue" wx:if="{{item.available_lunch}}">午餐可点</text>
            <text class="pill pill-blue" wx:if="{{item.available_dinner}}">晚餐可点</text>
            <text class="pill {{item.sale_status ? 'pill-green' : 'pill-amber'}}">{{item.sale_status ? '上架中' : '已下架'}}</text>
          </view>
        </view>
        <view class="product-actions-rail">
          <button class="ghost-btn product-tool-btn" size="mini" data-product="{{item}}" bindtap="editProduct">编辑</button>
          <button class="secondary-btn product-tool-btn" size="mini" data-product="{{item}}" bindtap="toggleSaleStatus">
            {{item.sale_status ? '下架' : '上架'}}
          </button>
        </view>
      </view>
    </view>
    <view wx:if="{{!filteredProducts.length}}" class="empty-copy">当前条件下没有商品，试试清空筛选。</view>
  </view>

  <view class="card editor-card">
    <view class="section-head">
      <text class="section-title">{{editingId ? '编辑商品' : '新增商品'}}</text>
      <text class="section-subtitle">{{editingId ? '修改后立即生效' : '保存后可直接上架'}}</text>
    </view>
    <view class="editor-section">
      <view class="field-block">
        <text class="field-label">商品分类</text>
        <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
          <view class="input picker-input">{{categoryOptions[categoryIndex] || '请选择分类'}}</view>
        </picker>
      </view>
      <view class="field-block">
        <text class="field-label">商品名称</text>
        <input class="input" placeholder="例如：招牌鸡饭" value="{{form.name}}" data-key="name" bindinput="onInput" />
      </view>
      <view class="field-block">
        <text class="field-label">菜品介绍</text>
        <textarea class="textarea" placeholder="写清口味、分量、推荐搭配，让用户更容易下单。" value="{{form.description}}" data-key="description" bindinput="onInput" maxlength="200"></textarea>
      </view>
    </view>

    <view class="editor-section">
      <text class="editor-section-title">图片</text>
      <view class="image-upload-panel">
        <view class="image-preview-wrap">
          <image wx:if="{{form.image_preview_url || form.image_url}}" class="preview-image" src="{{form.image_preview_url || form.image_url}}" mode="aspectFill"></image>
          <view wx:else class="image-placeholder">暂无图片</view>
        </view>
        <view class="image-upload-actions">
          <button class="ghost-btn upload-btn" bindtap="chooseImage">{{form.image_url ? '重新上传图片' : '上传本地图片'}}</button>
          <button wx:if="{{form.image_url}}" class="danger-btn upload-btn" bindtap="clearImage">移除当前图片</button>
          <text class="upload-tip">建议上传清晰的方图，用户端展示会更稳定。</text>
        </view>
      </view>
    </view>

    <view class="editor-section">
      <text class="editor-section-title">价格、库存、时段</text>
      <view class="field-grid">
        <view class="field-block field-grid-item">
          <text class="field-label">价格</text>
          <input class="input" placeholder="自动套餐价填 0，其它单点填 MYR" value="{{form.price_amount}}" data-key="price_amount" bindinput="onInput" />
        </view>
        <view class="field-block field-grid-item">
          <text class="field-label">库存</text>
          <input class="input" placeholder="可售数量" value="{{form.stock_qty}}" data-key="stock_qty" bindinput="onInput" />
        </view>
      </view>
      <view class="switch-grid">
        <view class="switch-card">
          <text class="switch-title">午餐可点</text>
          <switch checked="{{form.available_lunch}}" data-key="available_lunch" bindchange="onSwitchChange" color="#0f172a"></switch>
        </view>
        <view class="switch-card">
          <text class="switch-title">晚餐可点</text>
          <switch checked="{{form.available_dinner}}" data-key="available_dinner" bindchange="onSwitchChange" color="#0f172a"></switch>
        </view>
      </view>
    </view>
    <view class="editor-actions">
      <button class="primary-btn editor-primary" bindtap="saveProduct">保存</button>
      <button wx:if="{{editingId}}" class="ghost-btn editor-secondary" bindtap="cancelEdit">取消编辑</button>
    </view>
  </view>
</view>
