.shop-logo-preview {
  width: 172rpx;
  height: 172rpx;
  border-radius: 18rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
  box-shadow: none;
}

.field-block {
  margin-bottom: 14rpx;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #334155;
}

.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 18rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border-radius: 14rpx;
  border: 1rpx solid #d8e0e8;
  font-size: 26rpx;
  color: #0f172a;
  line-height: 1.6;
}

.payment-section {
  margin-top: 18rpx;
}

.payment-head {
  margin-bottom: 14rpx;
}

.payment-upload-card {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.payment-upload-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.payment-upload-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.payment-upload-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #475569;
}

.payment-qr-preview {
  width: 100%;
  height: 280rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.secondary-btn {
  margin: 0;
  min-width: 128rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #e2e8f0;
  color: #0f172a;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0 8rpx;
}
