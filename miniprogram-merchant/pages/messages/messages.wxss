.message-row {
  margin-bottom: 12rpx;
  padding: 18rpx;
}

.message-row .primary-btn {
  margin-top: 12rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  font-size: 22rpx;
  border-radius: 12rpx;
}

.content-preview {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
