.proof-image {
  width: 100%;
  height: 420rpx;
  margin-top: 16rpx;
  border-radius: 14rpx;
  background: #eef2ff;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.proof-empty {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}
