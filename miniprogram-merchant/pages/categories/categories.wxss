.category-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
}

.category-item:last-child {
  border-bottom: 0;
}

.category-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.category-name {
  display: block;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 700;
}

.category-actions {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.category-btn {
  min-width: 82rpx;
  margin: 0;
  min-height: 52rpx;
  line-height: 52rpx;
  font-size: 20rpx;
  border-radius: 10rpx;
}

.table-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 0 10rpx;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
}

.table-head-main,
.table-head-side {
  color: #64748b;
  font-size: 20rpx;
  font-weight: 600;
}

.editor-card {
  margin-top: 4rpx;
}

.editor-section {
  margin-top: 14rpx;
}

.field-block {
  margin-bottom: 14rpx;
}

.field-label {
  display: block;
  margin-bottom: 8rpx;
  color: #334155;
  font-size: 20rpx;
  font-weight: 700;
}

.field-grid {
  display: flex;
  gap: 12rpx;
  align-items: stretch;
}

.field-grid-item {
  flex: 1;
  margin-bottom: 0;
}

.switch-card {
  flex: 1;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(214, 222, 231, 0.9);
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.switch-copy {
  color: #64748b;
  font-size: 22rpx;
}

.editor-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 8rpx;
}

.editor-primary,
.editor-secondary {
  flex: 1;
}
