<view class="page">
  <view class="hero-card detail-hero" wx:if="{{order}}">
    <view class="detail-hero-top">
      <view class="detail-hero-copy">
        <text class="eyebrow">订单状态</text>
        <text class="hero-title">{{paymentBanner.title}}</text>
        <text class="hero-note">{{order.order_no}}</text>
      </view>
      <view class="hero-amount-box">
        <text class="hero-amount-label">订单金额</text>
        <text class="hero-amount-value">MYR {{order.total_amount}}</text>
      </view>
    </view>
    <view class="hero-meta">
      <text class="meta-pill">{{order.order_status_text}}</text>
      <text class="meta-pill">{{order.payment_status_text}}</text>
      <text class="meta-pill">下一步 {{paymentBanner.nextAction}}</text>
    </view>
    <view class="status-banner status-{{paymentBanner.tone}}">
      <text class="status-banner-title">{{paymentBanner.title}}</text>
      <text class="status-banner-copy">{{paymentBanner.copy}}</text>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{payment && (order.payment_status === 'UNPAID' || order.payment_status === 'FAILED' || order.payment_status === 'PROOF_UPLOADED')}}">
    <view class="section-head">
      <text class="section-title">当前动作</text>
      <text class="section-subtitle">先处理付款，再等待商家确认</text>
    </view>
    <view class="proof-panel proof-panel-priority">
      <image
        wx:if="{{payment.proof_image_url}}"
        class="proof-image"
        src="{{payment.proof_image_url}}"
        mode="aspectFit"
        lazy-load="true"
        bindtap="previewProofImage"
        binderror="handleProofError"
      />
      <view wx:if="{{payment.proof_image_url && proofImageFailed}}" class="proof-empty">
        <text class="line">截图已保存，但当前预览加载失败。</text>
        <button class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
      </view>
      <view wx:if="{{!payment.proof_image_url}}" class="proof-empty">
        <text class="line">还没有上传付款成功截图。</text>
      </view>
      <text class="line muted" wx:if="{{order.payment_status === 'FAILED'}}">商家未通过当前截图，请重新上传清晰截图。</text>
      <text class="line muted" wx:if="{{order.payment_status === 'PROOF_UPLOADED'}}">截图已提交，请等待商家确认，不需要重复上传。</text>
      <text class="line muted" wx:if="{{order.payment_status === 'UNPAID'}}">先完成转账，再上传付款截图。</text>
      <button wx:if="{{payment.proof_image_url}}" class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
      <button
        wx:if="{{order.payment_status === 'UNPAID' || order.payment_status === 'FAILED'}}"
        class="primary-btn proof-btn proof-btn-primary"
        bindtap="choosePaymentProof"
        loading="{{uploading}}"
      >
        {{payment.proof_image_url ? '重新上传付款截图' : '上传付款截图'}}
      </button>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{timeline.length}}">
    <view class="section-head">
      <text class="section-title">订单进度</text>
      <text class="section-subtitle">查看完整流程</text>
    </view>
    <view class="timeline">
      <view wx:for="{{timeline}}" wx:key="key" class="timeline-item">
        <view class="timeline-mark-wrap">
          <view class="timeline-mark {{item.done ? 'timeline-mark-done' : item.active ? 'timeline-mark-active' : ''}}"></view>
          <view wx:if="{{index !== timeline.length - 1}}" class="timeline-line {{item.done ? 'timeline-line-done' : ''}}"></view>
        </view>
        <view class="timeline-copy">
          <text class="timeline-title {{item.active ? 'timeline-title-active' : ''}}">{{item.title}}</text>
          <text class="timeline-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{order}}">
    <view class="section-head">
      <text class="section-title">配送信息</text>
      <text class="section-subtitle">收货信息</text>
    </view>
    <view class="info-row">
      <text class="info-label">收货人</text>
      <text class="info-value">{{order.receiver_name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{order.receiver_mobile}}</text>
    </view>
    <view class="info-row info-row-block">
      <text class="info-label">配送地址</text>
      <text class="info-value">{{order.receiver_address}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.created_at}}</text>
    </view>
    <view class="info-row" wx:if="{{payment}}">
      <text class="info-label">支付方式</text>
      <text class="info-value">{{payment.channel_code}}</text>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{payment && order.payment_status !== 'UNPAID' && order.payment_status !== 'FAILED' && order.payment_status !== 'PROOF_UPLOADED'}}">
    <view class="section-head">
      <text class="section-title">付款截图</text>
      <text class="section-subtitle">付款凭证</text>
    </view>
    <view class="proof-panel">
      <image
        wx:if="{{payment.proof_image_url}}"
        class="proof-image"
        src="{{payment.proof_image_url}}"
        mode="aspectFit"
        lazy-load="true"
        bindtap="previewProofImage"
        binderror="handleProofError"
      />
      <view wx:if="{{payment.proof_image_url && proofImageFailed}}" class="proof-empty">
        <text class="line">截图已保存，但当前预览加载失败。</text>
        <button class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
      </view>
      <view wx:if="{{!payment.proof_image_url}}" class="proof-empty">
        <text class="line">还没有上传付款成功截图。</text>
      </view>
      <text class="line muted" wx:if="{{order.payment_status === 'SUCCESS'}}">商家已确认到账，订单可以继续往下配送。</text>
      <button wx:if="{{payment.proof_image_url}}" class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{items.length}}">
    <view class="section-head">
      <text class="section-title">商品明细</text>
      <text class="section-subtitle">{{items.length}} 项</text>
    </view>
    <view wx:for="{{items}}" wx:key="id" class="item-row">
      <view>
        <text class="item-name">{{item.product_name_snapshot}}</text>
        <text wx:if="{{item.selected_options_text}}" class="item-qty">{{item.selected_options_text}}</text>
        <text class="item-qty">数量 x{{item.quantity}}</text>
      </view>
      <text class="item-amount">MYR {{item.line_amount}}</text>
    </view>
  </view>
</view>
