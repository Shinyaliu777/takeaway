<view class="page">
  <view class="hero-card detail-hero" wx:if="{{order}}">
    <text class="eyebrow">ORDER DETAIL</text>
    <text class="hero-title">{{order.order_status_text}}</text>
    <text class="hero-note">{{order.order_no}}</text>
    <view class="hero-meta">
      <text class="meta-pill">{{order.payment_status_text}}</text>
      <text class="meta-pill">MYR {{order.total_amount}}</text>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{order}}">
    <view class="section-head">
      <text class="section-title">配送信息</text>
      <text class="section-subtitle">收货与下单信息</text>
    </view>
    <view class="info-row">
      <text class="info-label">收货人</text>
      <text class="info-value">{{order.receiver_name}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{order.receiver_mobile}}</text>
    </view>
    <view class="info-row info-row-block">
      <text class="info-label">配送地址</text>
      <text class="info-value">{{order.receiver_address}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.created_at}}</text>
    </view>
    <view class="info-row" wx:if="{{payment}}">
      <text class="info-label">支付方式</text>
      <text class="info-value">{{payment.channel_code}}</text>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{payment}}">
    <view class="section-head">
      <text class="section-title">付款截图</text>
      <text class="section-subtitle">上传成功后等待商家手动确认</text>
    </view>
    <view class="proof-panel">
      <image
        wx:if="{{payment.proof_image_url}}"
        class="proof-image"
        src="{{payment.proof_image_url}}"
        mode="aspectFit"
        lazy-load="true"
        bindtap="previewProofImage"
        binderror="handleProofError"
      />
      <view wx:if="{{payment.proof_image_url && proofImageFailed}}" class="proof-empty">
        <text class="line">截图已保存，但当前预览加载失败。</text>
        <button class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
      </view>
      <view wx:if="{{!payment.proof_image_url}}" class="proof-empty">
        <text class="line">还没有上传付款成功截图。</text>
      </view>
      <text class="line muted" wx:if="{{order.payment_status === 'FAILED'}}">商家未通过当前截图，请重新上传清晰截图。</text>
      <text class="line muted" wx:if="{{order.payment_status === 'PROOF_UPLOADED'}}">截图已提交，等待商家确认到账。</text>
      <button wx:if="{{payment.proof_image_url}}" class="ghost-btn proof-secondary-btn" bindtap="previewProofImage">查看大图</button>
      <button
        wx:if="{{order.order_status === 'PENDING_PAYMENT' || order.payment_status === 'FAILED' || order.payment_status === 'PROOF_UPLOADED'}}"
        class="primary-btn proof-btn"
        bindtap="choosePaymentProof"
        loading="{{uploading}}"
      >
        {{payment.proof_image_url ? '重新上传付款截图' : '上传付款截图'}}
      </button>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{items.length}}">
    <view class="section-head">
      <text class="section-title">商品明细</text>
      <text class="section-subtitle">本单已确认商品</text>
    </view>
    <view wx:for="{{items}}" wx:key="id" class="item-row">
      <view>
        <text class="item-name">{{item.product_name_snapshot}}</text>
        <text wx:if="{{item.selected_options_text}}" class="item-qty">{{item.selected_options_text}}</text>
        <text class="item-qty">数量 x{{item.quantity}}</text>
      </view>
      <text class="item-amount">MYR {{item.line_amount}}</text>
    </view>
  </view>
</view>
