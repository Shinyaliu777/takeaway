.detail-hero {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #381b14, #5f281d);
  border: 0;
  box-shadow: 0 18rpx 40rpx rgba(67, 34, 24, 0.2);
}

.detail-hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.detail-hero-copy {
  flex: 1;
}

.hero-amount-box {
  min-width: 210rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 246, 238, 0.12);
  text-align: right;
}

.hero-amount-label {
  display: block;
  font-size: 18rpx;
  color: #f7dcc7;
}

.hero-amount-value {
  display: block;
  margin-top: 6rpx;
  font-size: 38rpx;
  line-height: 1;
  color: #fff8f1;
  font-weight: 900;
}

.detail-hero .eyebrow,
.detail-hero .hero-title,
.detail-hero .hero-note,
.detail-hero .meta-pill {
  color: #fff8f1;
}

.detail-hero .meta-pill {
  background: rgba(255, 246, 238, 0.12);
  border: 0;
}

.detail-hero .status-banner {
  margin-top: 18rpx;
}

.detail-card {
  padding: 22rpx;
}

.status-banner {
  padding: 16rpx;
  border-radius: 14rpx;
  border: 0;
}

.status-warning {
  background: linear-gradient(135deg, #fff0cf, #ffe3b2);
}

.status-info {
  background: linear-gradient(135deg, #ffe9df, #fff3ec);
}

.status-success {
  background: linear-gradient(135deg, #eef8ef, #dff2e2);
}

.status-danger {
  background: linear-gradient(135deg, #ffe3df, #fff1ef);
}

.status-banner-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #3b2a1f;
}

.status-banner-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #6f5a49;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
}

.timeline-mark-wrap {
  width: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-mark {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e7dccd;
  border: 4rpx solid #f8f1e7;
  box-shadow: 0 0 0 1rpx #ddcfba;
}

.timeline-mark-done {
  background: #6f8e60;
  box-shadow: 0 0 0 1rpx #6f8e60;
}

.timeline-mark-active {
  background: #b46a30;
  box-shadow: 0 0 0 1rpx #b46a30;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  min-height: 44rpx;
  background: #eadfce;
  margin-top: 6rpx;
}

.timeline-line-done {
  background: #b7d0bb;
}

.timeline-copy {
  flex: 1;
  padding-bottom: 18rpx;
}

.timeline-title {
  display: block;
  color: #6b5544;
  font-size: 26rpx;
  font-weight: 700;
}

.timeline-title-active {
  color: #2f2118;
}

.timeline-desc {
  display: block;
  margin-top: 4rpx;
  color: #8a6d56;
  font-size: 20rpx;
  line-height: 1.45;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #efe4d4;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row-block {
  align-items: flex-start;
}

.info-label {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #977a64;
}

.info-value {
  text-align: right;
  font-size: 24rpx;
  color: #5b4738;
}

.item-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #efe4d4;
}

.item-row:last-child {
  border-bottom: 0;
}

.item-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #3b2a1f;
}

.item-qty {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d6956;
}

.item-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #8f5a2e;
}

.proof-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.proof-panel-priority {
  gap: 14rpx;
}

.proof-image {
  width: 100%;
  height: 380rpx;
  border-radius: 22rpx;
  background: #f7f0e5;
  border: 0;
}

.proof-empty {
  padding: 36rpx 28rpx;
  border-radius: 22rpx;
  background: #fff8ef;
  border: 0;
}

.upload-progress-card {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff6ea;
  border: 1rpx solid #f1debe;
}

.upload-progress-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
}

.upload-progress-title {
  font-size: 22rpx;
  color: #6b4e39;
}

.upload-progress-percent {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #8f5a2e;
}

.upload-progress-track {
  margin-top: 12rpx;
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #eddcc5;
}

.upload-progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #9e602d, #cf8746);
}

.upload-error-card {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff0ee;
  border: 1rpx solid #f2c1bb;
}

.upload-error-title {
  display: block;
  font-size: 22rpx;
  font-weight: 800;
  color: #8c2f23;
}

.upload-error-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #9a4b40;
}

.muted {
  color: #8a6d56;
}

.proof-btn {
  margin-top: 8rpx;
}

.proof-btn-primary {
  min-height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.proof-secondary-btn {
  align-self: flex-start;
  min-width: 220rpx;
}
