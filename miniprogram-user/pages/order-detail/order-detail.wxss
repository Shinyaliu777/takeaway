.detail-hero {
  margin-bottom: 24rpx;
}

.detail-card {
  padding: 26rpx;
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: flex;
  gap: 18rpx;
}

.timeline-mark-wrap {
  width: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-mark {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e7dccd;
  border: 4rpx solid #f8f1e7;
  box-shadow: 0 0 0 1rpx #ddcfba;
}

.timeline-mark-done {
  background: #6f8e60;
  box-shadow: 0 0 0 1rpx #6f8e60;
}

.timeline-mark-active {
  background: #b46a30;
  box-shadow: 0 0 0 1rpx #b46a30;
}

.timeline-line {
  width: 2rpx;
  flex: 1;
  min-height: 44rpx;
  background: #eadfce;
  margin-top: 6rpx;
}

.timeline-line-done {
  background: #b7d0bb;
}

.timeline-copy {
  flex: 1;
  padding-bottom: 18rpx;
}

.timeline-title {
  display: block;
  color: #6b5544;
  font-size: 28rpx;
  font-weight: 700;
}

.timeline-title-active {
  color: #2f2118;
}

.timeline-desc {
  display: block;
  margin-top: 6rpx;
  color: #8a6d56;
  font-size: 22rpx;
  line-height: 1.6;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #efe4d4;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row-block {
  align-items: flex-start;
}

.info-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8a6d56;
}

.info-value {
  text-align: right;
  font-size: 26rpx;
  color: #3b2a1f;
}

.item-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #efe4d4;
}

.item-row:last-child {
  border-bottom: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #3b2a1f;
}

.item-qty {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7d6956;
}

.item-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #8f5a2e;
}

.proof-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.proof-image {
  width: 100%;
  height: 380rpx;
  border-radius: 22rpx;
  background: #f7f0e5;
  border: 1rpx solid #eadfce;
}

.proof-empty {
  padding: 36rpx 28rpx;
  border-radius: 22rpx;
  background: #fff8ef;
  border: 1rpx solid #eadfce;
}

.muted {
  color: #8a6d56;
}

.proof-btn {
  margin-top: 8rpx;
}

.proof-secondary-btn {
  align-self: flex-start;
  min-width: 220rpx;
}
