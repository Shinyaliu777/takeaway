<view class="page">
  <view class="hero-card cart-hero">
    <view class="cart-hero-top">
      <view class="cart-hero-copy">
        <text class="hero-title">确认订单</text>
        <text class="hero-note">{{pricingSummary.checkoutHint}}</text>
      </view>
      <view class="amount-spotlight">
        <text class="amount-spotlight-label">应付</text>
        <text class="amount-spotlight-value">MYR {{totalAmount}}</text>
      </view>
    </view>
    <view class="hero-meta">
      <text class="meta-pill">已选 {{pricingPreview.selectedCount}} 份</text>
      <text class="meta-pill">套餐 {{pricingSummary.comboCount}} 组</text>
      <text class="meta-pill">单点 MYR {{pricingSummary.sideTotalText}}</text>
    </view>
    <view class="hero-breakdown">
      <view class="breakdown-line">
        <text class="breakdown-key">套餐金额</text>
        <text class="breakdown-value">MYR {{pricingSummary.comboTotalText}}</text>
      </view>
      <view class="breakdown-line">
        <text class="breakdown-key">单点金额</text>
        <text class="breakdown-value">MYR {{pricingSummary.sideTotalText}}</text>
      </view>
    </view>
  </view>

  <view class="sheet-card">
    <view class="sheet-head">
      <text class="sheet-title">菜品</text>
      <text class="sheet-meta">{{cart.length}} 项</text>
    </view>
    <view wx:if="{{cart.length}}">
      <view wx:for="{{cart}}" wx:key="cart_key" class="cart-item-card">
        <view class="cart-item-main">
          <view class="cart-item-head">
            <text class="dish-name">{{item.name}}</text>
            <text wx:if="{{item.dish_kind === 'meat'}}" class="kind-tag kind-tag-meat">荤菜</text>
            <text wx:elif="{{item.dish_kind === 'veg'}}" class="kind-tag kind-tag-veg">素菜</text>
            <text wx:else class="kind-tag kind-tag-side">单点</text>
          </view>
          <text wx:if="{{item.selection_label}}" class="line">{{item.selection_label}}</text>
          <text class="dish-meta">数量 {{item.quantity}}</text>
          <text wx:if="{{item.lineAmount}}" class="line subtle">MYR {{item.lineAmount}}</text>
        </view>
        <view class="cart-actions">
          <button class="qty-btn qty-btn-light" size="mini" data-id="{{item.cart_key}}" bindtap="decreaseQty">-</button>
          <button class="qty-btn" size="mini" data-id="{{item.cart_key}}" bindtap="increaseQty">+</button>
          <button class="text-btn" size="mini" data-id="{{item.cart_key}}" bindtap="removeItem">删除</button>
        </view>
      </view>
    </view>
    <view wx:else class="empty-box">
      <text class="line">购物车还没有菜品。</text>
      <button class="ghost-btn panel-btn" bindtap="goMenu">回到菜单</button>
    </view>
  </view>

  <view class="sheet-card">
    <view class="sheet-head">
      <text class="sheet-title">结算结果</text>
      <text class="sheet-meta">金额以这里为准</text>
    </view>
    <view class="settlement-card">
      <view class="settlement-banner {{pricingPreview.matched ? 'is-ready' : 'is-pending'}}">
        <text class="settlement-banner-title">{{pricingPreview.matched ? '可以创建订单' : '还不能结算'}}</text>
        <text class="settlement-banner-copy">{{pricingPreview.matched ? pricingPreview.summaryText : (pricingPreview.missingHint || pricingPreview.summaryText)}}</text>
      </view>
      <view wx:if="{{pricingPreview.comboLines.length}}">
        <view wx:for="{{pricingPreview.comboLines}}" wx:key="index" class="combo-card">
          <view class="combo-head">
            <text class="combo-name">{{item.name}}</text>
            <text class="combo-price">MYR {{item.price}}</text>
          </view>
          <view class="combo-items">
            <text wx:for="{{item.items}}" wx:key="index" class="combo-item-chip">{{item.name}}</text>
          </view>
        </view>
      </view>
      <view wx:if="{{pricingPreview.sideLines.length}}">
        <view class="subsection-head">
          <text class="subsection-title">额外单点</text>
        </view>
        <view wx:for="{{pricingPreview.sideLines}}" wx:key="name" class="preview-line">
          <text>{{item.name}} x{{item.quantity}}</text>
          <text>MYR {{item.amount}}</text>
        </view>
      </view>
      <view class="total-line">
        <text>合计</text>
        <text>MYR {{totalAmount}}</text>
      </view>
    </view>
  </view>

  <view class="sheet-card">
    <view class="sheet-head">
      <text class="sheet-title">地址</text>
    </view>
    <view wx:if="{{defaultAddress}}" class="address-card address-card-compact">
      <text class="dish-name">{{defaultAddress.receiver_name}}</text>
      <text class="dish-meta">{{defaultAddress.receiver_mobile}}</text>
      <text class="line">{{defaultAddress.detail_address}}</text>
    </view>
    <view wx:else class="empty-box">
      <text class="line">{{cart.length ? '还没选择配送地址。' : '先去菜单选菜。'}}</text>
    </view>
    <button class="ghost-btn panel-btn" bindtap="goAddresses">管理地址</button>
  </view>

  <view class="action-panel status-panel">
    <view class="status-copy">
      <text class="status-title">创建订单</text>
      <text class="line">创建后完成转账，再上传付款截图给商家确认。</text>
      <text wx:if="{{!pricingPreview.matched && cart.length}}" class="line strong">{{pricingSummary.checkoutHint}}</text>
      <text wx:if="{{orderHint}}" class="line strong">{{orderHint}}</text>
    </view>
    <button class="panel-btn primary-btn action-btn-primary" bindtap="checkout" disabled="{{!canCheckout}}">创建订单</button>
    <button wx:if="{{cart.length}}" class="panel-btn ghost-btn subtle-ghost-btn action-btn-secondary" bindtap="clearCart">清空购物车</button>
  </view>
</view>
