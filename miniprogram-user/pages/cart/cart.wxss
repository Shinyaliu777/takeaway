.cart-hero {
  margin-bottom: 20rpx;
  background: linear-gradient(180deg, #fff5e7 0%, #eed3ba 100%);
  border: 0;
  box-shadow: 0 14rpx 34rpx rgba(92, 59, 34, 0.08);
}

.cart-hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.cart-hero-copy {
  flex: 1;
}

.amount-spotlight {
  min-width: 196rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(52, 25, 17, 0.08);
  text-align: right;
}

.amount-spotlight-label {
  display: block;
  font-size: 18rpx;
  color: #8a6d56;
}

.amount-spotlight-value {
  display: block;
  margin-top: 6rpx;
  font-size: 38rpx;
  line-height: 1;
  color: #3b2a1f;
  font-weight: 900;
}

.hero-breakdown {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(90, 58, 37, 0.12);
}

.breakdown-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.breakdown-key {
  color: #8a6d56;
  font-size: 20rpx;
}

.breakdown-value {
  color: #3b2a1f;
  font-size: 24rpx;
  font-weight: 800;
}

.sheet-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fffdf9;
  border: 1rpx solid rgba(230, 212, 194, 0.82);
}

.sheet-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.sheet-title {
  color: #2f2118;
  font-size: 26rpx;
  font-weight: 900;
}

.sheet-meta {
  color: #8a6d56;
  font-size: 20rpx;
}

.cart-item-card,
.address-card {
  background: #fffdf8;
  border-radius: 18rpx;
  padding: 18rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(230, 212, 194, 0.82);
  box-shadow: none;
}

.cart-item-card {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  align-items: center;
}

.cart-item-main {
  flex: 1;
  min-width: 0;
}

.cart-item-head {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #2f2118;
}

.dish-meta {
  display: block;
  margin-top: 6rpx;
  color: #7d6956;
  font-size: 22rpx;
}

.kind-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.kind-tag-meat {
  background: #fef2f2;
  color: #b42318;
}

.kind-tag-veg {
  background: #edf7ed;
  color: #2f6b3d;
}

.kind-tag-side {
  background: #fff5e8;
  color: #9a5a28;
}

.subtle {
  color: #9a5a28;
}

.cart-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  justify-content: flex-end;
}

.qty-btn,
.text-btn {
  margin: 0;
  border-radius: 14rpx;
  min-height: 58rpx;
  line-height: 58rpx;
  font-size: 22rpx;
}

.qty-btn {
  background: #b54826;
  color: #fff;
  width: 58rpx;
  padding: 0;
}

.qty-btn-light {
  background: #f5ead8;
  color: #6d4a2d;
}

.text-btn {
  background: #f8ece7;
  color: #8f4d2c;
}

.settlement-card {
  border-radius: 14rpx;
  background: #fff9f1;
  padding: 16rpx;
}

.settlement-banner {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  margin-bottom: 10rpx;
}

.settlement-banner.is-ready {
  background: linear-gradient(135deg, #edf7ed, #e4f1e5);
}

.settlement-banner.is-pending {
  background: linear-gradient(135deg, #fff1e7, #fce6d8);
}

.settlement-banner-title {
  display: block;
  color: #3b2a1f;
  font-size: 22rpx;
  font-weight: 900;
}

.settlement-banner-copy {
  display: block;
  margin-top: 4rpx;
  color: #6b5544;
  font-size: 20rpx;
  line-height: 1.4;
}

.combo-card {
  padding: 14rpx 0;
  border-radius: 0;
  background: transparent;
  border: 0;
  border-top: 1rpx solid rgba(224, 210, 195, 0.74);
  margin-top: 12rpx;
}

.combo-card:first-of-type {
  border-top: 0;
  padding-top: 6rpx;
}

.combo-head,
.preview-line,
.total-line {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.combo-name,
.combo-price,
.total-line {
  color: #3b2a1f;
  font-size: 22rpx;
  font-weight: 700;
}

.combo-items {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.combo-item-chip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: #f8efe4;
  border: 0;
  color: #6b5544;
  font-size: 18rpx;
}

.subsection-head {
  margin-top: 14rpx;
}

.subsection-title {
  color: #7d5d41;
  font-size: 20rpx;
  font-weight: 700;
}

.preview-line {
  margin-top: 10rpx;
  color: #5c4533;
  font-size: 22rpx;
}

.total-line {
  padding-top: 14rpx;
  margin-top: 14rpx;
  border-top: 1rpx solid #eadfce;
}

.address-card-compact {
  margin-bottom: 0;
}

.empty-box {
  background: #fffbf5;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid #eadfce;
}

.status-panel {
  background: linear-gradient(180deg, #fffaf3 0%, #f5e6d6 100%);
  border: 0;
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 28rpx rgba(88, 59, 36, 0.08);
}

.status-copy {
  margin-bottom: 14rpx;
}

.status-title {
  display: block;
  color: #3b2a1f;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 4rpx;
}

.action-btn-primary {
  margin-top: 14rpx;
  min-height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.action-btn-secondary {
  margin-top: 10rpx;
}

.subtle-ghost-btn {
  opacity: 0.74;
}
