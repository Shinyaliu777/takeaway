<view class="page">
  <view class="hero-card compact-hero">
    <view class="hero-top">
      <view class="hero-brand">
        <image wx:if="{{shop.logo_url_preview || shop.logo_url}}" class="hero-logo" src="{{shop.logo_url_preview || shop.logo_url}}" mode="aspectFill" lazy-load="true"></image>
        <view class="hero-copy">
          <text class="eyebrow">店铺</text>
          <text class="hero-title">{{shop.name}}</text>
        </view>
      </view>
      <text class="status-badge {{shopOpen ? 'is-open' : 'is-closed'}}">{{shopOpen ? '营业中' : '休息中'}}</text>
    </view>
    <view class="hero-summary">
      <text class="hero-subline">{{shop.notice || (isGuest ? '先看菜，再登录下单。' : '直接选菜，系统会自动按套餐结算。')}}</text>
      <text class="hero-utility">营业时间 {{shop.business_hours}} · 加饭 +{{shop.extra_rice_price || 2}} MYR</text>
    </view>
    <view wx:if="{{isGuest}}" class="guest-banner">
      <text class="guest-banner-copy">游客可先浏览，加入购物车时再登录。</text>
    </view>
  </view>

  <view class="section-shell quick-nav-shell">
    <view class="quick-nav-bar">
      <button class="nav-chip nav-chip-order" plain="true" bindtap="goOrders">
        <text class="nav-chip-title">订单</text>
      </button>
      <button class="nav-chip" plain="true" bindtap="goMessages">
        <text class="nav-chip-title">消息</text>
      </button>
      <button class="nav-chip" plain="true" bindtap="goProfile">
        <text class="nav-chip-title">我的</text>
      </button>
    </view>
  </view>

  <view class="section-shell payment-shell">
    <view class="section-head payment-head">
      <text class="section-title">付款方式</text>
      <text class="section-subtitle">付款后截图并上传到订单</text>
    </view>
    <view class="payment-grid">
      <view
        wx:for="{{paymentCodes}}"
        wx:key="key"
        class="payment-card {{item.key === selectedPaymentKey ? 'payment-card-active' : ''}}"
        bindtap="previewPaymentQr"
        data-key="{{item.key}}"
      >
        <view class="payment-card-top">
          <text class="payment-title">{{item.title}}</text>
          <text class="payment-state {{item.uploaded ? 'payment-state-ready' : 'payment-state-empty'}}">
            {{item.isFallbackActive ? '演示图' : item.uploaded ? '可查看' : '未上传'}}
          </text>
        </view>
        <text class="payment-copy">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{featuredProducts.length}}" class="section-shell">
    <view class="section-head">
      <text class="section-title">推荐</text>
    </view>
    <scroll-view class="feature-strip" scroll-x="true" show-scrollbar="false">
      <view class="feature-row">
        <view wx:for="{{featuredProducts}}" wx:key="index" class="feature-tile" bindtap="goFeaturedProduct" data-product-id="{{item.target_product_id}}">
          <image wx:if="{{item.image_url}}" class="feature-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="true" catchtap="previewDishImage" data-image-url="{{item.image_url}}"></image>
          <text class="feature-name">{{item.title}}</text>
          <text class="feature-price">{{item.subtitle}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-shell">
    <view class="compact-controls">
      <view class="section-head inline-head">
        <text class="section-title">时段</text>
      </view>
      <view class="period-switch">
        <view class="period-pill {{currentPeriod === 'lunch' ? 'period-pill-active' : ''}}" bindtap="selectPeriod" data-period="lunch">
          <text class="period-title">午餐</text>
        </view>
        <view class="period-pill {{currentPeriod === 'dinner' ? 'period-pill-active' : ''}}" bindtap="selectPeriod" data-period="dinner">
          <text class="period-title">晚餐</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-shell">
    <view class="compact-controls compact-controls-last">
      <view class="section-head inline-head">
        <text class="section-title">分类</text>
      </view>
      <view class="chips">
        <text class="chip {{selectedCategoryId === 0 ? 'chip-active' : ''}}" bindtap="selectCategory" data-category-id="0">全部</text>
        <text
          wx:for="{{categories}}"
          wx:key="id"
          class="chip {{selectedCategoryId === item.id ? 'chip-active' : ''}}"
          bindtap="selectCategory"
          data-category-id="{{item.id}}"
        >{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section-shell menu-shell">
    <view class="section-head menu-head">
      <text class="section-title">{{currentPeriod === 'lunch' ? '午餐菜单' : '晚餐菜单'}}</text>
      <text class="section-subtitle">{{filteredProducts.length}} 道</text>
    </view>
    <view wx:if="{{filteredProducts.length}}">
      <view wx:for="{{filteredProducts}}" wx:key="id" class="dish-card">
        <image wx:if="{{item.image_preview_url || item.image_url}}" class="dish-image" src="{{item.image_preview_url || item.image_url}}" mode="aspectFill" lazy-load="true" catchtap="previewDishImage" data-image-url="{{item.image_preview_url || item.image_url}}"></image>
        <view class="dish-main">
          <view class="dish-copy">
            <view class="dish-name-row">
              <text class="dish-name">{{item.name}}</text>
              <text class="dish-tag {{item.dish_kind === 'meat' ? 'dish-tag-meat' : item.dish_kind === 'veg' ? 'dish-tag-veg' : 'dish-tag-side'}}">
                {{item.dish_kind === 'meat' ? '荤菜' : item.dish_kind === 'veg' ? '素菜' : item.name.includes('米饭') ? '米饭' : '单点'}}
              </text>
            </view>
            <text class="dish-meta">{{item.description || '现做现送。'}}</text>
          </view>
          <view class="dish-bottom">
            <view class="dish-side">
              <text wx:if="{{item.dish_kind !== 'meat' && item.dish_kind !== 'veg'}}" class="dish-price">MYR {{item.price_amount}}</text>
              <text class="dish-stock">{{item.stock_qty > 0 ? '剩余 ' + item.stock_qty : '售罄'}}</text>
            </view>
            <view class="stepper {{isGuest ? 'stepper-guest' : ''}}">
              <text wx:if="{{isGuest}}" class="stepper-guest-copy">登录后加菜</text>
              <block wx:else>
                <button wx:if="{{item.selected_qty}}" class="stepper-btn stepper-minus" size="mini" catchtap="decreaseDish" data-product-id="{{item.id}}">-</button>
                <text class="stepper-count">{{item.selected_qty || 0}}</text>
                <button class="stepper-btn add-btn" size="mini" catchtap="increaseDish" data-product="{{item}}">+</button>
              </block>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-box">
      <text class="line">这个时段还没有可点菜品。</text>
    </view>
  </view>

  <view class="bottom-nav-spacer"></view>

  <view class="action-panel compact-panel">
    <view class="pricing-inline">
      <text class="pricing-inline-main">MYR {{pricingPreview.totalAmount}}</text>
      <text class="pricing-inline-copy">{{pricingPreview.summaryText}}</text>
      <text wx:if="{{pricingPreview.missingHint && !pricingPreview.matched}}" class="pricing-inline-missing">{{pricingPreview.missingHint}}</text>
      <text class="pricing-inline-total">已选 {{pricingPreview.selectedCount}} 份</text>
    </view>
    <button class="panel-btn panel-primary panel-cart-btn" bindtap="goCart">{{isGuest ? '登录后下单' : '去核对订单'}}{{isGuest ? '' : cartLabel}}</button>
  </view>

  <view wx:if="{{showPaymentSheet}}" class="payment-sheet-mask" bindtap="closePaymentSheet">
    <view class="payment-sheet" catchtap="stopPaymentSheet">
      <view class="payment-sheet-head">
        <view>
          <text class="payment-sheet-title">{{selectedPaymentCode.title}} 收款码</text>
          <text class="payment-sheet-subtitle">{{selectedPaymentCode.isFallbackActive ? '线上收款码失效，当前展示演示图用于联调，请在订单详情继续上传演示付款截图。' : '转账完成后，请到订单详情上传付款截图'}}</text>
        </view>
        <text class="payment-sheet-close" bindtap="closePaymentSheet">关闭</text>
      </view>
      <view class="payment-sheet-tabs">
        <view
          wx:for="{{paymentCodes}}"
          wx:key="key"
          class="payment-sheet-tab {{item.key === selectedPaymentKey ? 'payment-sheet-tab-active' : ''}}"
          bindtap="selectPaymentCode"
          data-key="{{item.key}}"
        >
          {{item.title}}
        </view>
      </view>
      <view class="payment-sheet-body">
        <image
          wx:if="{{selectedPaymentCode.isFallbackActive && selectedPaymentKey === 'wechat'}}"
          class="payment-sheet-image"
          src="../../assets/payment-qr-wechat.png"
          mode="aspectFit"
          show-menu-by-longpress="true"
          lazy-load="true"
        />
        <image
          wx:elif="{{selectedPaymentCode.isFallbackActive && selectedPaymentKey === 'alipay'}}"
          class="payment-sheet-image"
          src="../../assets/payment-qr-alipay.png"
          mode="aspectFit"
          show-menu-by-longpress="true"
          lazy-load="true"
        />
        <image
          wx:elif="{{selectedPaymentCode.isFallbackActive && selectedPaymentKey === 'tng'}}"
          class="payment-sheet-image"
          src="../../assets/payment-qr-tng.png"
          mode="aspectFit"
          show-menu-by-longpress="true"
          lazy-load="true"
        />
        <image
          wx:elif="{{sheetImagePath}}"
          class="payment-sheet-image"
          src="{{sheetImagePath}}"
          mode="aspectFit"
          show-menu-by-longpress="true"
          lazy-load="true"
        />
        <view wx:elif="{{sheetImageLoading}}" class="payment-sheet-empty">
          <text class="payment-sheet-empty-copy">收款码加载中</text>
        </view>
        <view wx:elif="{{sheetImageError}}" class="payment-sheet-empty">
          <text class="payment-sheet-empty-copy">收款码加载失败，请稍后再试</text>
        </view>
        <view wx:else class="payment-sheet-empty">
          <text class="payment-sheet-empty-copy">商家暂未上传该收款码</text>
        </view>
      </view>
      <button class="payment-sheet-save" bindtap="savePaymentQr" data-key="{{selectedPaymentKey}}">保存收款码到相册</button>
    </view>
  </view>
</view>
