<view class="page">
  <view class="hero-card compact-hero">
    <view class="hero-top">
      <view class="hero-brand">
        <image wx:if="{{shop.logo_url}}" class="hero-logo" src="{{shop.logo_url}}" mode="aspectFill" lazy-load="true"></image>
        <view class="hero-copy">
          <text class="eyebrow">ORDER STATION</text>
          <text class="hero-title">{{shop.name}}</text>
          <text class="hero-subline">{{shop.notice || '先登录，再直接选菜，系统自动拆成套餐结算。'}}</text>
        </view>
      </view>
      <view class="status-badge {{shopOpen ? 'is-open' : 'is-closed'}}">
        {{shopOpen ? '营业中' : '休息中'}}
      </view>
    </view>
    <view class="hero-meta">
      <text class="meta-pill">营业时间 {{shop.business_hours}}</text>
      <text class="meta-pill">套餐默认含饭</text>
      <text class="meta-pill">额外米饭 +2 MYR</text>
    </view>
    <view class="hero-tools">
      <button class="hero-tool" bindtap="goOrders">订单</button>
      <button class="hero-tool" bindtap="goMessages">消息</button>
      <button class="hero-tool" bindtap="goProfile">我的</button>
    </view>
  </view>

  <view wx:if="{{featuredProducts.length}}" class="section-shell">
    <view class="section-head">
      <text class="section-title">推荐商品</text>
      <text class="section-subtitle">商家精选</text>
    </view>
    <scroll-view class="feature-strip" scroll-x="true" show-scrollbar="false">
      <view class="feature-row">
        <view wx:for="{{featuredProducts}}" wx:key="index" class="feature-tile" bindtap="goFeaturedProduct" data-product-id="{{item.target_product_id}}">
          <image wx:if="{{item.image_url}}" class="feature-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="true"></image>
          <text class="feature-name">{{item.title}}</text>
          <text class="feature-price">{{item.subtitle}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section-shell">
    <view class="section-head">
      <text class="section-title">时段</text>
      <text class="section-subtitle">只显示当前可点菜品</text>
    </view>
    <view class="period-switch">
      <view class="period-pill {{currentPeriod === 'lunch' ? 'period-pill-active' : ''}}" bindtap="selectPeriod" data-period="lunch">
        <text class="period-title">午餐</text>
        <text class="period-copy">午餐可点</text>
      </view>
      <view class="period-pill {{currentPeriod === 'dinner' ? 'period-pill-active' : ''}}" bindtap="selectPeriod" data-period="dinner">
        <text class="period-title">晚餐</text>
        <text class="period-copy">晚餐可点</text>
      </view>
    </view>
  </view>

  <view class="section-shell">
    <view class="section-head">
      <text class="section-title">分类</text>
      <text class="section-subtitle">按菜品类型筛选</text>
    </view>
    <view class="chips">
      <text class="chip {{selectedCategoryId === 0 ? 'chip-active' : ''}}" bindtap="selectCategory" data-category-id="0">全部</text>
      <text
        wx:for="{{categories}}"
        wx:key="id"
        class="chip {{selectedCategoryId === item.id ? 'chip-active' : ''}}"
        bindtap="selectCategory"
        data-category-id="{{item.id}}"
      >{{item.name}}</text>
    </view>
  </view>

  <view class="section-shell menu-shell">
    <view class="section-head">
      <text class="section-title">{{currentPeriod === 'lunch' ? '午餐菜单' : '晚餐菜单'}}</text>
      <text class="section-subtitle">直接加减菜品，系统实时拆套餐</text>
    </view>
    <view wx:if="{{filteredProducts.length}}">
      <view wx:for="{{filteredProducts}}" wx:key="id" class="dish-card">
        <image wx:if="{{item.image_url}}" class="dish-image" src="{{item.image_url}}" mode="aspectFill" lazy-load="true"></image>
        <view class="dish-main">
          <view class="dish-copy">
            <view class="dish-name-row">
              <text class="dish-name">{{item.name}}</text>
              <text class="dish-tag {{item.dish_kind === 'meat' ? 'dish-tag-meat' : item.dish_kind === 'veg' ? 'dish-tag-veg' : 'dish-tag-side'}}">
                {{item.dish_kind === 'meat' ? '荤菜' : item.dish_kind === 'veg' ? '素菜' : item.name.includes('米饭') ? '米饭' : '单点'}}
              </text>
            </view>
            <text class="dish-meta">{{item.description || '现做热食，适合外卖场景。'}}</text>
          </view>
          <view class="dish-bottom">
            <view>
              <text wx:if="{{item.dish_kind !== 'meat' && item.dish_kind !== 'veg'}}" class="dish-price">MYR {{item.price_amount}}</text>
              <text class="dish-stock">库存 {{item.stock_qty}}</text>
            </view>
            <view class="stepper">
              <button wx:if="{{item.selected_qty}}" class="stepper-btn stepper-minus" size="mini" catchtap="decreaseDish" data-product-id="{{item.id}}">-</button>
              <text class="stepper-count">{{item.selected_qty || 0}}</text>
              <button class="stepper-btn add-btn" size="mini" catchtap="increaseDish" data-product="{{item}}">+</button>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-box">
      <text class="line">这个时段还没有可点菜品。</text>
    </view>
  </view>

  <view class="bottom-nav-spacer"></view>

  <view class="action-panel compact-panel">
    <view class="pricing-inline">
      <text class="pricing-inline-main">已选 {{pricingPreview.selectedCount}} 份</text>
      <text class="pricing-inline-copy">{{pricingPreview.summaryText}}</text>
      <text class="pricing-inline-total">MYR {{pricingPreview.totalAmount}}</text>
    </view>
    <button class="panel-btn panel-primary panel-cart-btn" bindtap="goCart">查看购物车{{cartLabel}}</button>
  </view>
</view>
