.hero-card {
  background:
    radial-gradient(circle at top right, rgba(191, 77, 44, 0.12), transparent 30%),
    linear-gradient(180deg, #fff7ee 0%, #f2dbc4 100%);
  border-radius: 28rpx;
  padding: 22rpx 22rpx 16rpx;
  color: #3b2a1f;
  margin-bottom: 4rpx;
  border: 0;
  box-shadow: 0 12rpx 28rpx rgba(92, 59, 34, 0.08);
}

.compact-hero {
  margin-bottom: 10rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.hero-brand {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  flex: 1;
}

.hero-copy {
  flex: 1;
}

.hero-logo {
  width: 86rpx;
  height: 86rpx;
  border-radius: 20rpx;
  border: 0;
  background: #fff;
  flex-shrink: 0;
  box-shadow: 0 8rpx 16rpx rgba(64, 39, 20, 0.08);
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  color: #8a6148;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-title {
  display: block;
  margin-top: 4rpx;
  font-size: 56rpx;
  line-height: 1.05;
  color: #2f2118;
  font-weight: 900;
}

.hero-summary {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(135, 94, 67, 0.14);
}

.hero-subline {
  display: block;
  font-size: 26rpx;
  line-height: 1.52;
  color: #5a4132;
  font-weight: 600;
}

.hero-utility {
  display: block;
  margin-top: 6rpx;
  color: #8f6a52;
  font-size: 22rpx;
}

.status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  border: 0;
}

.status-badge.is-open {
  color: #2f6b3d;
  background: #edf8ef;
  border-color: #cde7d3;
}

.status-badge.is-closed {
  color: #9d4a22;
  background: #fff1e7;
  border-color: #f2d6c4;
}

.guest-banner {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(191, 77, 44, 0.05);
  border: 0;
}

.guest-banner-copy {
  display: block;
  color: #8a6148;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 500;
}

.section-shell {
  margin-bottom: 8rpx;
}

.quick-nav-shell {
  margin-top: 2rpx;
}

.quick-nav-bar {
  display: flex;
  align-items: stretch;
  gap: 8rpx;
}

.nav-chip {
  flex: 1;
  margin: 0;
  min-height: 68rpx;
  border-radius: 16rpx;
  border: 0;
  background: rgba(255, 249, 243, 0.82);
  color: #2f2118;
  padding: 10rpx 8rpx;
  text-align: center;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 0;
  box-shadow: none;
}

.nav-chip::after {
  border: 0;
}

.nav-chip-order {
  background: linear-gradient(135deg, #5b311e, #ab4c27);
  color: #fffaf3;
  border-color: transparent;
  box-shadow: 0 8rpx 16rpx rgba(181, 72, 38, 0.14);
}

.nav-chip-title {
  display: block;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 800;
}

.nav-chip:not(.nav-chip-order) .nav-chip-title {
  color: #5a3d2d;
}

.nav-chip:not(.nav-chip-order) {
  background: rgba(255, 255, 255, 0.72);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.section-title {
  color: #2f2118;
  font-size: 28rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #8f6a52;
  font-size: 20rpx;
}

.inline-head {
  margin-bottom: 8rpx;
}

.compact-controls {
  padding-top: 4rpx;
}

.compact-controls-last {
  margin-bottom: 2rpx;
}

.feature-strip {
  white-space: nowrap;
}

.feature-row {
  display: flex;
  gap: 8rpx;
}

.feature-tile {
  width: 258rpx;
  background: #faf1e5;
  border-radius: 16rpx;
  padding: 8rpx;
  border: 0;
  box-sizing: border-box;
}

.feature-image {
  width: 100%;
  height: 150rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: #f3ebdf;
}

.feature-name {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #3b2a1f;
}

.feature-price {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  line-height: 1.35;
  color: #8a6d56;
}

.period-switch {
  display: flex;
  gap: 8rpx;
}

.period-pill {
  flex: 1;
  padding: 12rpx 0;
  border-radius: 999rpx;
  background: #f8efe4;
  border: 0;
  text-align: center;
}

.period-pill-active {
  background: linear-gradient(135deg, #5b311e, #ab4c27);
  border-color: transparent;
}

.period-title {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #3b2a1f;
}

.period-copy {
  display: none;
}

.period-pill-active .period-title,
.period-pill-active .period-copy {
  color: #fffaf3;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 8rpx;
}

.chip {
  background: transparent;
  color: #6f5443;
  border: 1rpx solid rgba(193, 162, 134, 0.38);
  border-radius: 999rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.chip-active {
  background: #5b311e;
  color: #fff7f0;
  border-color: #5b311e;
}

.menu-shell {
  margin-bottom: 8rpx;
}

.menu-head {
  margin-bottom: 8rpx;
}

.dish-card {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 0;
  background: transparent;
  border-radius: 0;
  margin-bottom: 0;
  border: 0;
  border-bottom: 1rpx solid rgba(208, 187, 168, 0.55);
  box-shadow: none;
}

.dish-image {
  width: 192rpx;
  height: 192rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #f3ebdf;
}

.dish-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-copy {
  min-height: 0;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.dish-name {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #2f2118;
}

.dish-tag {
  padding: 2rpx 0;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.dish-tag-meat {
  background: transparent;
  color: #b42318;
}

.dish-tag-veg {
  background: transparent;
  color: #2f6b3d;
}

.dish-tag-side {
  background: transparent;
  color: #9a5a28;
}

.dish-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7e6857;
  line-height: 1.45;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 16rpx;
}

.dish-side {
  display: flex;
  flex-direction: column;
}

.dish-price {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #b54826;
}

.dish-stock {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8a725f;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stepper-guest {
  justify-content: flex-end;
}

.stepper-guest-copy {
  color: #8f674d;
  font-size: 22rpx;
  font-weight: 700;
}

.stepper-btn {
  margin: 0;
  width: 58rpx;
  min-height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  padding: 0;
  font-size: 26rpx;
  font-weight: 800;
}

.stepper-minus {
  background: #f5ead8;
  color: #6d4a2d;
}

.stepper-count {
  min-width: 28rpx;
  text-align: center;
  color: #6d4a2d;
  font-size: 26rpx;
  font-weight: 800;
}

.add-btn {
  background: #b54826;
  color: #fff;
}

.empty-box {
  background: #fffbf5;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid #eadfce;
}

.line {
  display: block;
  color: #6b5544;
  font-size: 26rpx;
  line-height: 1.6;
}

.bottom-nav-spacer {
  height: 148rpx;
}

.action-panel {
  position: fixed;
  left: 16rpx;
  right: 16rpx;
  bottom: 14rpx;
  background: linear-gradient(135deg, #3b2017, #5e2b1c);
  border-radius: 24rpx;
  padding: 16rpx 16rpx 14rpx;
  box-shadow: 0 18rpx 44rpx rgba(73, 35, 22, 0.28);
  border: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.compact-panel {
  min-height: 92rpx;
}

.pricing-inline {
  flex: 1;
  min-width: 0;
}

.pricing-inline-main {
  display: block;
  color: #fff8f1;
  font-size: 52rpx;
  font-weight: 900;
}

.pricing-inline-copy {
  display: block;
  margin-top: 2rpx;
  color: rgba(255, 235, 223, 0.9);
  font-size: 22rpx;
  line-height: 1.4;
}

.pricing-inline-missing {
  display: block;
  margin-top: 4rpx;
  color: #ffd6a8;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
}

.pricing-inline-total {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 232, 214, 0.72);
  font-size: 21rpx;
  font-weight: 700;
}

.panel-btn {
  margin: 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  min-height: 82rpx;
  line-height: 82rpx;
}

.panel-cart-btn {
  width: 268rpx;
  flex-shrink: 0;
  background: #fff7ee;
  color: #4f2418;
  font-weight: 900;
}

.panel-primary {
  box-shadow: none;
}
