.hero-card {
  background: linear-gradient(180deg, #fffdfa 0%, #f6ede0 100%);
  border-radius: 30rpx;
  padding: 26rpx;
  color: #3b2a1f;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(229, 214, 194, 0.9);
}

.compact-hero {
  margin-bottom: 16rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.hero-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.hero-copy {
  flex: 1;
}

.hero-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(226, 216, 199, 0.9);
  background: #fff;
  flex-shrink: 0;
}

.eyebrow {
  display: block;
  font-size: 20rpx;
  color: #b38354;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  display: block;
  margin-top: 6rpx;
  font-size: 42rpx;
  line-height: 1.15;
  color: #2f2118;
  font-weight: 800;
}

.hero-subline {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d6956;
}

.status-badge {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #fff6e8;
  border: 1rpx solid rgba(226, 202, 168, 0.9);
}

.status-badge.is-open {
  color: #2f6b3d;
  background: #edf8ef;
  border-color: #cde7d3;
}

.status-badge.is-closed {
  color: #9d4a22;
  background: #fff1e7;
  border-color: #f2d6c4;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff8ef;
  border: 1rpx solid rgba(226, 202, 168, 0.9);
  color: #775a43;
  font-size: 20rpx;
}

.hero-tools {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.hero-tool {
  margin: 0;
  min-height: 58rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #fff8ef;
  color: #704f39;
  border: 1rpx solid rgba(226, 202, 168, 0.9);
  font-size: 22rpx;
}

.hero-tool::after {
  border: 0;
}

.section-shell {
  margin-bottom: 18rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.section-title {
  color: #2f2118;
  font-size: 32rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #8a6d56;
  font-size: 20rpx;
}

.feature-strip {
  white-space: nowrap;
}

.feature-row {
  display: flex;
  gap: 12rpx;
}

.feature-tile {
  width: 272rpx;
  background: #fffaf4;
  border-radius: 22rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(228, 216, 199, 0.9);
  box-sizing: border-box;
}

.feature-image {
  width: 100%;
  height: 144rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: #f3ebdf;
}

.feature-name {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #3b2a1f;
}

.feature-price {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.5;
  color: #9a5a28;
}

.period-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.period-pill {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fffaf4;
  border: 1rpx solid rgba(228, 216, 199, 0.9);
}

.period-pill-active {
  background: linear-gradient(135deg, #6f4424, #b46a30);
  border-color: transparent;
}

.period-title {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #3b2a1f;
}

.period-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8a6d56;
}

.period-pill-active .period-title,
.period-pill-active .period-copy {
  color: #fffaf3;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  background: #fff9f0;
  color: #7d5d41;
  border: 1rpx solid #e6d7c1;
  border-radius: 16rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.chip-active {
  background: #6f8e60;
  color: #f8fff4;
  border-color: #6f8e60;
}

.menu-shell {
  margin-bottom: 12rpx;
}

.dish-card {
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
  background: #fffdf9;
  border-radius: 24rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid rgba(228, 216, 199, 0.88);
  box-shadow: 0 6rpx 16rpx rgba(78, 56, 33, 0.04);
}

.dish-image {
  width: 164rpx;
  height: 164rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #f3ebdf;
}

.dish-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-copy {
  min-height: 0;
}

.dish-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.dish-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #2f2118;
}

.dish-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
}

.dish-tag-meat {
  background: #fef2f2;
  color: #b42318;
}

.dish-tag-veg {
  background: #edf7ed;
  color: #2f6b3d;
}

.dish-tag-side {
  background: #fff5e8;
  color: #9a5a28;
}

.dish-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #7d6956;
  line-height: 1.6;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12rpx;
  margin-top: 12rpx;
}

.dish-price {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #9a5a28;
}

.dish-stock {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #7d6956;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stepper-btn {
  margin: 0;
  width: 58rpx;
  min-height: 58rpx;
  line-height: 58rpx;
  border-radius: 14rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 800;
}

.stepper-minus {
  background: #f5ead8;
  color: #6d4a2d;
}

.stepper-count {
  min-width: 28rpx;
  text-align: center;
  color: #6d4a2d;
  font-size: 24rpx;
  font-weight: 800;
}

.add-btn {
  background: #6f4424;
  color: #fff;
}

.empty-box {
  background: #fffbf5;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  border: 1rpx solid #eadfce;
}

.line {
  display: block;
  color: #6b5544;
  font-size: 22rpx;
  line-height: 1.6;
}

.bottom-nav-spacer {
  height: 148rpx;
}

.action-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 18rpx;
  background: rgba(255, 252, 247, 0.98);
  border-radius: 22rpx;
  padding: 14rpx 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(77, 58, 40, 0.08);
  border: 1rpx solid rgba(228, 216, 199, 0.94);
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.compact-panel {
  min-height: 92rpx;
}

.pricing-inline {
  flex: 1;
  min-width: 0;
}

.pricing-inline-main {
  display: block;
  color: #2f2118;
  font-size: 28rpx;
  font-weight: 800;
}

.pricing-inline-copy {
  display: block;
  margin-top: 4rpx;
  color: #7d6956;
  font-size: 20rpx;
  line-height: 1.4;
}

.pricing-inline-missing {
  display: block;
  margin-top: 4rpx;
  color: #b45309;
  font-size: 20rpx;
  line-height: 1.4;
  font-weight: 700;
}

.pricing-inline-total {
  display: block;
  margin-top: 6rpx;
  color: #9a5a28;
  font-size: 28rpx;
  font-weight: 800;
}

.panel-btn {
  margin: 0;
  border-radius: 16rpx;
  font-size: 24rpx;
  min-height: 74rpx;
  line-height: 74rpx;
}

.panel-cart-btn {
  width: 240rpx;
  flex-shrink: 0;
}

.panel-primary {
  background: linear-gradient(135deg, #6f4424, #b46a30);
  color: #fff;
  font-weight: 800;
}
