<view class="page">
  <view class="login-shell">
    <text class="eyebrow">继续下单</text>
    <text class="hero-title">登录后继续结算</text>
    <text class="hero-note">只在加入购物车、地址和订单状态场景需要登录。</text>
    <text class="login-promise">不改菜单，不丢进度，登录后直接回到刚才的位置。</text>
    <button class="primary-btn one-tap-btn" bindtap="submitLogin" loading="{{submitting}}">微信一键登录并继续</button>
    <text class="login-reassure">微信授权完成后继续当前流程。</text>
    <text class="login-footnote">{{statusText}}</text>
  </view>
</view>
