.page {
  min-height: 100vh;
  padding: 132rpx 28rpx 24rpx;
  background:
    radial-gradient(circle at top right, rgba(191, 77, 44, 0.1), transparent 28%),
    linear-gradient(180deg, #fbf3ea 0%, #f1decb 100%);
  box-sizing: border-box;
}

.login-shell {
  padding: 16rpx 4rpx 0;
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  color: #8a6148;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-title {
  display: block;
  margin-top: 8rpx;
  font-size: 62rpx;
  line-height: 1.06;
  color: #2f2118;
  font-weight: 900;
}

.hero-note {
  display: block;
  margin-top: 16rpx;
  color: #6b5341;
  font-size: 26rpx;
  line-height: 1.56;
}

.one-tap-btn {
  margin-top: 34rpx;
  height: 98rpx;
  line-height: 98rpx;
  font-size: 30rpx;
  font-weight: 900;
  border-radius: 20rpx;
  box-shadow: 0 14rpx 28rpx rgba(181, 72, 38, 0.18);
}

.login-promise {
  display: block;
  margin-top: 22rpx;
  color: #4c382b;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
}

.login-reassure {
  display: block;
  margin-top: 18rpx;
  font-size: 20rpx;
  color: #8f7159;
}

.login-footnote {
  display: block;
  margin-top: 20rpx;
  font-size: 20rpx;
  color: #907460;
}
