.list-hero {
  margin-bottom: 24rpx;
}

.message-card {
  background: #fffdf9;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #eadfce;
  box-shadow: 0 6rpx 16rpx rgba(78, 56, 33, 0.04);
}

.message-card.is-read {
  opacity: 0.72;
}

.message-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.message-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #431407;
}

.message-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8a6d56;
}

.message-copy {
  display: block;
  margin-top: 18rpx;
  color: #6f5a49;
  font-size: 26rpx;
  line-height: 1.65;
}

.mini-action {
  margin: 18rpx 0 0;
}

.read-tag {
  display: inline-block;
  margin-top: 18rpx;
  color: #8a6d56;
  font-size: 22rpx;
}

.empty-card {
  margin-top: 10rpx;
}
