.detail-page {
  padding: 16rpx 20rpx 160rpx;
}

.detail-hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-hero-copy {
  display: flex;
  flex-direction: column;
}

.detail-kicker {
  display: block;
  color: #8a6048;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.detail-title {
  display: block;
  margin-top: 8rpx;
  font-size: 58rpx;
  line-height: 1.06;
  font-weight: 900;
  color: #2f2118;
}

.detail-note {
  display: block;
  margin-top: 10rpx;
  color: #705646;
  font-size: 26rpx;
  line-height: 1.5;
}

.detail-hero-image {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  background: #f3ebdf;
  box-shadow: 0 12rpx 26rpx rgba(78, 56, 33, 0.08);
}

.detail-card {
  margin: 14rpx 0 0;
  position: relative;
  background: #fffdf9;
  border-radius: 22rpx;
  padding: 26rpx 24rpx;
  border: 0;
  box-shadow: 0 8rpx 18rpx rgba(78, 56, 33, 0.05);
}

.headline-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 24rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(92, 67, 48, 0.1);
}

.headline-main {
  flex: 1;
}

.price-line {
  display: block;
  font-size: 56rpx;
  line-height: 1;
  font-weight: 900;
  color: #b54826;
}

.stock-line {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8d735f;
}

.order-hint {
  flex-shrink: 0;
  max-width: 230rpx;
  text-align: right;
}

.order-hint-label {
  display: block;
  font-size: 18rpx;
  color: #9b7f6a;
}

.order-hint-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #3b2a1f;
}

.intro-block {
  margin-top: 24rpx;
}

.browse-banner {
  margin-top: 18rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(181, 72, 38, 0.04);
  border: 0;
}

.browse-banner-copy {
  display: block;
  color: #8a6148;
  font-size: 18rpx;
  line-height: 1.4;
  font-weight: 500;
}

.section-title {
  display: block;
  color: #8a6b55;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.intro-copy {
  display: block;
  margin-top: 12rpx;
  color: #6b5341;
  font-size: 26rpx;
  line-height: 1.62;
}

.option-group {
  margin-top: 18rpx;
}

.option-title {
  display: block;
  margin-bottom: 12rpx;
  color: #3b2a1f;
  font-size: 24rpx;
  font-weight: 700;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.option-pill {
  min-width: 132rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f6ebde;
  border: 1rpx solid rgba(181, 72, 38, 0.08);
  color: #5f4534;
  font-size: 23rpx;
  text-align: center;
}

.option-pill-active {
  background: #b54826;
  border-color: #b54826;
  color: #fffdf9;
}

.sticky-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  background: linear-gradient(135deg, #3b2017, #5e2b1c);
  border-radius: 22rpx;
  border: 0;
  box-shadow: 0 18rpx 40rpx rgba(73, 35, 22, 0.24);
}

.cart-meta {
  flex: 1;
}

.cart-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 231, 214, 0.68);
}

.cart-count {
  display: block;
  margin-top: 6rpx;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #fff8f1;
}

.cart-btn {
  margin: 0;
  height: 74rpx;
  line-height: 74rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.ghost-btn {
  background: rgba(255, 247, 238, 0.16);
  color: #fff3ea;
}

.primary-btn {
  background: linear-gradient(135deg, #e06a39, #b94724);
  color: #fffaf5;
}

.loading-shell {
  margin: 120rpx 0 0;
  padding: 40rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  text-align: center;
  color: #6f5a49;
}
