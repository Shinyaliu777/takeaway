<view class="page detail-page" wx:if="{{product}}">
  <view class="detail-hero">
    <image class="detail-hero-image" src="{{product.image_preview_url || product.image_url}}" mode="aspectFill" lazy-load="true" bindtap="previewProductImage"></image>
    <view class="detail-hero-copy">
      <text class="detail-kicker">{{category ? category.name : '单品'}}</text>
      <text class="detail-title">{{product.name}}</text>
      <text class="detail-note">{{category && (category.name === '荤菜' || category.name === '素菜') ? '按套餐规则一起结算' : '作为单点加入购物车'}}</text>
    </view>
  </view>

  <view class="detail-card">
    <view class="headline-row">
      <view class="headline-main">
        <text wx:if="{{!category || (category.name !== '荤菜' && category.name !== '素菜')}}" class="price-line">MYR {{product.price_amount}}</text>
        <text class="stock-line">{{product.stock_qty > 0 ? '剩余 ' + product.stock_qty + ' 份' : '暂时售罄'}}</text>
      </view>
      <view class="order-hint">
        <text class="order-hint-label">下单说明</text>
        <text class="order-hint-copy">{{category && (category.name === '荤菜' || category.name === '素菜') ? '按套餐规则结算' : '作为单点加入购物车'}}</text>
      </view>
    </view>

    <view wx:if="{{isGuest}}" class="browse-banner">
      <text class="browse-banner-copy">先看菜，加入购物车时再登录。</text>
    </view>

    <view class="intro-block">
      <text class="section-title">菜品说明</text>
      <text class="intro-copy">{{product.description || '现做热食，适合外带和配送。'}}</text>
    </view>

    <view class="intro-block" wx:if="{{product.option_groups && product.option_groups.length}}">
      <text class="section-title">选项</text>
      <view wx:for="{{product.option_groups}}" wx:for-item="group" wx:key="group_name" class="option-group">
        <text class="option-title">{{group.group_name}}</text>
        <view class="option-list">
          <view
            wx:for="{{group.options}}"
            wx:for-item="option"
            wx:key="*this"
            class="option-pill {{selectedOptions[group.group_name] === option ? 'option-pill-active' : ''}}"
            data-group="{{group.group_name}}"
            data-option="{{option}}"
            bindtap="chooseOption"
          >
            {{option}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="sticky-bar">
    <view class="cart-meta">
      <text class="cart-label">{{isGuest ? '先确认菜品' : '当前购物车'}}</text>
      <text class="cart-count">{{isGuest ? '登录后即可加入并继续下单' : cartCount + ' 件，去核对订单'}}</text>
    </view>
    <button class="cart-btn ghost-btn" bindtap="goCart">{{isGuest ? '登录后核对' : '查看购物车'}}</button>
    <button class="cart-btn primary-btn" bindtap="addToCart">{{isGuest ? '登录后加菜' : '加入购物车'}}</button>
  </view>
</view>

<view class="page detail-page" wx:elif="{{loading}}">
  <view class="loading-shell">商品加载中...</view>
</view>
