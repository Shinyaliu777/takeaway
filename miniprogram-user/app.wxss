page {
  background: #f7f3eb;
  color: #1f2937;
}

.page {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #fffdf9;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(228, 216, 199, 0.78);
  box-shadow: 0 6rpx 16rpx rgba(78, 56, 33, 0.04);
}

.title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3b2a1f;
}

.line {
  display: block;
  margin-top: 8rpx;
  color: #645347;
  font-size: 24rpx;
  line-height: 1.65;
}

.strong {
  color: #1f2937;
  font-weight: 600;
}

.input {
  height: 78rpx;
  background: #fffaf2;
  border-radius: 16rpx;
  border: 1rpx solid #eadfce;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.primary-btn {
  margin-top: 0;
  background: linear-gradient(135deg, #6f4424, #b46a30);
  color: #ffffff;
  border-radius: 18rpx;
  min-height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  box-shadow: 0 8rpx 16rpx rgba(122, 77, 34, 0.12);
}

.primary-btn[disabled] {
  background: #d6d3d1;
  color: #6b7280;
  box-shadow: none;
}

.ghost-btn {
  background: #fff8ef;
  color: #6b4e39;
  border-radius: 18rpx;
  min-height: 74rpx;
  line-height: 74rpx;
  font-size: 24rpx;
  border: 1rpx solid #e9dcc8;
}

.primary-btn::after,
.ghost-btn::after {
  border: 0;
}

.hero-card {
  background: linear-gradient(180deg, #fffdfa 0%, #f7efe1 100%);
  border-radius: 30rpx;
  padding: 26rpx;
  color: #3b2a1f;
  border: 1rpx solid rgba(228, 216, 199, 0.9);
  box-shadow: 0 8rpx 20rpx rgba(84, 63, 43, 0.06);
}

.eyebrow {
  display: block;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  color: #9d6c44;
  margin-bottom: 10rpx;
}

.hero-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.08;
  color: #2c211a;
}

.hero-note {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  margin-top: 14rpx;
  color: #6e5847;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.meta-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff6ea;
  border: 1rpx solid rgba(226, 202, 168, 0.9);
  color: #7d5d41;
  font-size: 20rpx;
}

.section-shell {
  margin-bottom: 20rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.section-subtitle {
  color: #8a6d56;
  font-size: 20rpx;
}
